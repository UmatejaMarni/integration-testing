# IntelliJ IDEA project files
.idea/          # Ignore the entire .idea folder
*.iml           # Ignore IntelliJ module files

# Default ignored files (redundant if .idea/ is ignored, but kept for clarity)
.idea/shelf/
.idea/workspace.xml

# Build output
/out/
/target/
/build/

# Compiled class files
*.class

# Logs
*.log

# OS-specific files
.DS_Store
Thumbs.db

# Temporary files
*.swp
*.tmp
